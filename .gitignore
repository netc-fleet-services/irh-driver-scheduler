# Local env files (never commit secrets)
.env
.env.local
.env.*.local

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Python (in case we add scripts/ later)
__pycache__/
*.pyc
.venv/
venv/

# Node (only used for lint/format dev tools — not for build)
node_modules/
package-lock.json
npm-debug.log*

# Supabase: keep already-tracked migrations 1-7 in git (gitignore doesn't
# untrack them), but stop NEW SQL files / CLI working artifacts from being
# auto-staged. To intentionally commit a new migration, use `git add -f`.
supabase/
